GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.1-8b-instant
EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
FRONTEND_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///./sql_app.db
# Example PostgreSQL:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/smartbridge_ai

# Qdrant vector store for RAG
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_chunks

# Optional local embedded Qdrant path (used when QDRANT_URL is empty)
QDRANT_PATH=./qdrant_data

# MCP subprocess integration
MCP_ENABLED=true
MCP_TOOL_TIMEOUT_SECS=45
GITHUB_MCP_COMMAND=python -m platform_core.github_mcp_server
GITHUB_MCP_ENV_JSON=
GOOGLE_DRIVE_MCP_COMMAND=python -m platform_core.google_drive_mcp_server
GOOGLE_DRIVE_MCP_ENV_JSON=
OAUTH_STATE_TTL_SECS=900

# GitHub OAuth
# GitHub callback URL: http://localhost:8000/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=repo read:user user:email
# Optional PAT fallback for local shared GitHub access
GITHUB_PAT=

# Google OAuth
# Google redirect URI: http://localhost:8000/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_SCOPE=openid email profile https://www.googleapis.com/auth/drive

# Optional direct Google Drive service-account mode
# Share the target Drive folder with GOOGLE_SERVICE_ACCOUNT_EMAIL.
# Either set GOOGLE_SERVICE_ACCOUNT_JSON to the full JSON object on one line,
# or set GOOGLE_SERVICE_ACCOUNT_JSON_PATH to a local key file path.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Document analysis / SQL agent
DOCUMENT_SESSION_TTL_HOURS=2
SQL_AGENT_ROW_LIMIT=200
SQL_AGENT_TIMEOUT_MS=5000
